{
  "providers": {
    "lead_model": {
      "type": "openai_compatible",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key_env": "SILICONFLOW_LEAD_KEY",
      "models": {
        "text": "deepseek-ai/DeepSeek-V4-Flash"
      }
    },
    "researcher_model": {
      "type": "openai_compatible",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key_env": "SILICONFLOW_RESEARCHER_KEY",
      "models": {
        "text": "deepseek-ai/DeepSeek-V4-Flash"
      }
    },
    "extractor_model": {
      "type": "openai_compatible",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key_env": "SILICONFLOW_EXTRACTOR_KEY",
      "models": {
        "text": "deepseek-ai/DeepSeek-V4-Flash"
      }
    },
    "critic_model": {
      "type": "openai_compatible",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key_env": "SILICONFLOW_CRITIC_KEY",
      "models": {
        "text": "deepseek-ai/DeepSeek-V4-Flash"
      }
    },
    "writer_model": {
      "type": "openai_compatible",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key_env": "SILICONFLOW_WRITER_KEY",
      "models": {
        "text": "deepseek-ai/DeepSeek-V4-Flash"
      }
    },
    "vision_model": {
      "type": "openai_compatible",
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "api_key_env": "DASHSCOPE_API_KEY",
      "models": {
        "vision": "glm-5v-turbo"
      }
    }
  },
  "agents": {
    "lead": {
      "provider": "lead_model"
    },
    "researcher": {
      "provider": "researcher_model"
    },
    "extractor": {
      "provider": "extractor_model"
    },
    "critic": {
      "provider": "critic_model"
    },
    "writer": {
      "provider": "writer_model"
    },
    "judge": {
      "provider": "critic_model"
    },
    "vision": {
      "provider": "vision_model",
      "capability": "vision"
    },
    "browser": {
      "provider": "vision_model",
      "capability": "vision"
    },
    "default": {
      "provider": "researcher_model"
    }
  }
}
